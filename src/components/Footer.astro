---
interface Props {
  site: {
    name: string;
    email?: string;
    phone?: string;
    address?: string;
    abn?: string;
    socialLinks?: Array<{ label: string; url: string }>;
  };
}

const { site } = Astro.props;
const year = new Date().getFullYear();
const logoUrl = '/smart-choice-roof-restorations/uploads/logo.png';
---

<footer class="site-footer" data-theme="dark">
  <div class="site-footer__inner container">
    <div class="site-footer__brand-col">
      <a href="/smart-choice-roof-restorations/" class="site-footer__logo">
        <img src={logoUrl} alt={site.name} width="160" height="38" />
      </a>
      <p class="site-footer__tagline">Do It Once, Do It Smart!</p>
      <p class="site-footer__desc">Melbourne's trusted roof restoration specialists. 5.0 ★ rated — 43+ Google reviews.</p>
    </div>
    <div class="site-footer__columns">
      <div>
        <h2>Services</h2>
        <a href="#services">Tile Roof Restoration</a>
        <a href="#services">Metal Roof Restoration</a>
        <a href="#services">Roof Repairs</a>
        <a href="#services">Roof Respray</a>
        <a href="#services">All Services</a>
      </div>
      <div>
        <h2>Contact</h2>
        {site.phone && <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="site-footer__phone">{site.phone}</a>}
        {site.email && <a href={`mailto:${site.email}`}>{site.email}</a>}
        {site.address && <p>{site.address}</p>}
        {site.abn && <p class="site-footer__abn">ABN: {site.abn}</p>}
      </div>
      <div>
        <h2>Connect</h2>
        {site.socialLinks && site.socialLinks.length > 0
          ? site.socialLinks.map((link) => <a href={link.url} target="_blank" rel="noopener">{link.label}</a>)
          : null
        }
        <a href="#faq">FAQ</a>
      </div>
    </div>
  </div>
  <div class="site-footer__meta container">
    <span>&copy; {year} {site.name}. All rights reserved.</span>
    <a href="/smart-choice-roof-restorations/privacy/">Privacy Policy</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: none;
    background: var(--color-page);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    gap: var(--space-8);
    padding-block: var(--section-y-compact);
  }

  .site-footer__logo {
    display: inline-block;
    margin-bottom: var(--space-3);
  }

  .site-footer__logo img {
    height: 38px;
    width: auto;
    display: block;
  }

  .site-footer__tagline {
    margin-bottom: var(--space-2);
    color: var(--brand-primary);
    font-weight: 700;
    font-size: var(--text-md);
    font-style: italic;
  }

  .site-footer__desc {
    margin-bottom: 0;
    max-width: 22rem;
  }

  .site-footer__phone {
    font-size: var(--text-lg);
    font-weight: 700;
    color: #ffffff !important;
  }

  .site-footer__abn {
    font-size: var(--text-xs);
    opacity: 0.5;
    margin-top: var(--space-2);
  }

  .site-footer__columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .site-footer h2 {
    margin-bottom: var(--space-3);
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-footer a {
    display: block;
    width: fit-content;
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .site-footer a:hover {
    color: var(--color-text);
  }

  .site-footer p {
    max-width: 28rem;
    margin-bottom: 0;
    font-size: var(--text-sm);
  }

  .site-footer__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-rule);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .site-footer__meta a {
    margin: 0;
  }

  @media (max-width: 760px) {
    .site-footer__inner,
    .site-footer__columns {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .site-footer__meta {
      flex-direction: column;
    }
  }
</style>
