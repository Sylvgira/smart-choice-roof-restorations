---
const suburbs = [
  'Melbourne', 'Thomastown', 'Epping', 'Mill Park', 'South Morang',
  'Moonee Ponds', 'Essendon', 'Greensborough', 'Greenvale', 'Coburg',
  'Lalor', 'Reservoir', 'Broadmeadows', 'Preston', 'Tullamarine',
  'Balwyn North', 'Altona', 'Box Hill', 'Camberwell', 'Clayton',
  'Doncaster', 'Glen Iris', 'Heidelberg', 'Ivanhoe', 'Kew',
  'Laverton', 'Templestowe Lower'
];
---

<div class="service-area">
  <p class="service-area__intro">Proudly serving Melbourne and surrounding suburbs:</p>
  <div class="service-area__tags">
    {suburbs.map((suburb) => (
      <span class="service-area__tag">{suburb}</span>
    ))}
  </div>
</div>

<style>
  .service-area__intro {
    text-align: center;
    margin-bottom: var(--space-5);
    font-size: var(--text-md);
    color: var(--color-text-muted);
  }

  .service-area__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .service-area__tag {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-page);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
  }
</style>
