---
interface Service {
  id?: string;
  data: {
    title: string;
    summary: string;
  };
}

interface Props {
  services: Service[];
  variant?: 'grid' | 'list' | 'featured-first' | 'icon-grid';
}

const { services, variant = 'grid' } = Astro.props;

const fallbackIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M8 12a4 4 0 0 1 8 0"/><path d="M12 8v8"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34"/><polygon points="18 2 22 6 12 16 8 16 8 12 18 2"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="7" y1="3" x2="7" y2="6"/><line x1="17" y1="3" x2="17" y2="6"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
];
---

{ variant === 'icon-grid' ? (
  <div class="service-grid service-grid--icon-grid" data-theme="dark">
    {services.map((service, i) => (
      <div class="service-icon-card">
        <span class="service-icon-card__icon" set:html={fallbackIcons[i % fallbackIcons.length]} />
        <h3>{service.data.title}</h3>
        <p>{service.data.summary}</p>
      </div>
    ))}
  </div>
) : (
  <div class:list={['service-grid', `service-grid--${variant}`]}>
    {services.map((service) => (
      <div class="service-card">
        <h3>{service.data.title}</h3>
        <p>{service.data.summary}</p>
      </div>
    ))}
  </div>
) }

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .service-grid--list {
    grid-template-columns: 1fr;
  }

  .service-grid--list .service-card {
    display: grid;
    grid-template-columns: minmax(10rem, 0.45fr) minmax(0, 1fr) auto;
    gap: var(--space-5);
    align-items: start;
    min-height: auto;
  }

  .service-grid--featured-first .service-card:first-child {
    grid-column: span 2;
    min-height: 20rem;
    background: var(--color-section);
  }

  .service-card {
    display: flex;
    min-height: 17rem;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
  }

  .service-card h3 {
    margin-bottom: var(--space-4);
  }

  .service-card p {
    flex: 1;
  }

  /* --- icon-grid variant --- */

  .service-grid--icon-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .service-icon-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .service-icon-card:hover {
    background: var(--color-section);
  }

  .service-icon-card:nth-child(3n+2),
  .service-icon-card:nth-child(3n+3) {
    border-left: 1px solid var(--color-rule);
  }

  .service-icon-card:nth-child(n+4) {
    border-top: 1px solid var(--color-rule);
  }

  .service-icon-card__icon {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 2rem;
    height: 2rem;
    color: var(--color-icon-accent);
    flex-shrink: 0;
  }

  .service-icon-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-grid--icon-grid h3 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .service-grid--icon-grid p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-grid--list .service-card {
      display: flex;
    }

    .service-grid--featured-first .service-card:first-child {
      grid-column: auto;
    }

    .service-grid--icon-grid {
      grid-template-columns: 1fr 1fr;
    }

    .service-icon-card:nth-child(odd) {
      border-left: none;
    }

    .service-icon-card:nth-child(3) {
      border-top: 1px solid var(--color-rule);
    }
  }

  @media (max-width: 540px) {
    .service-grid--icon-grid {
      grid-template-columns: 1fr;
    }

    .service-icon-card {
      border-left: none !important;
      border-top: 1px solid var(--color-rule);
    }

    .service-icon-card:first-child {
      border-top: none;
    }
  }
</style>
